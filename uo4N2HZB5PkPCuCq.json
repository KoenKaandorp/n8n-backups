    {
      "parameters": {
        "jsCode": "const raw = $json.text || $json.data || '';\nlet pages = [];\nif (Array.isArray(raw)) pages = raw;\nelse if (typeof raw === 'string') {\n  pages = raw.split('\\f');\n  if (pages.length < 3) pages = raw.split(/\\n\\s*\\n\\s*\\n/);\n}\n// Cap to 30k chars to stay friendly with the model context\nconst paperText = pages.join('\\n\\n').slice(0, 30000);\nconst ctx = $('Loop Over Papers').item.json;\nreturn [{ json: { ...ctx, paper_text: paperText, paper_total_pages: pages.length } }];"
      },

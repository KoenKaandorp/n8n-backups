      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const prev = $('Fan Out Slides').item.json;\nconst resp = $json;\nconst imageUrl = resp.image_url || resp.image_url_png;\nif (!imageUrl) {\n  throw new Error('Bannerbear returned no image_url. Response: ' + JSON.stringify(resp).slice(0, 400));\n}\nreturn {\n  json: {\n    ...prev,\n    bannerbear_status: resp.status || 'completed',\n    bannerbear_image_url: imageUrl\n  }\n};"
      },
      "id": "8341bacc-1af0-4088-8bdb-56baa84a6d6e",
      "name": "Parse Bannerbear Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        496
      ]
    },
    {
      "parameters": {
        "jsCode": "const parent = $json;\nconst g = $('Globals').first().json;\nconst total = parent.total_slides;\n\nfunction pickTemplate(slideType) {\n  if (slideType === 'hook') return g.BANNERBEAR_TEMPLATE_HOOK;\n  if (slideType === 'cta') return g.BANNERBEAR_TEMPLATE_CTA;\n  return g.BANNERBEAR_TEMPLATE_CONTENT;\n}\n\nreturn parent.slides.map(slide => ({\n  json: {\n    _parent: { ...parent, slides: undefined },\n    slide_number: slide.slide_number,\n    slide_type: slide.slide_type,\n    headline: slide.headline,\n    body: slide.body,\n    footer: `${slide.slide_number}/${total} \\u00b7 ${g.FACULTY_NAME}`,\n    template_id: pickTemplate(slide.slide_type)\n  }\n}));"
      },
      "id": "dae6b9c1-2c9f-443d-b687-151d0d15999e",
      "name": "Fan Out Slides",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        496
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output || '';\nconst cleaned = raw.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/```\\s*$/i, '').trim();\nlet parsed;\ntry { parsed = JSON.parse(cleaned); } catch (e) {\n  throw new Error('Carousel concept invalid JSON: ' + e.message + ' | raw: ' + raw.slice(0, 300));\n}\nconst expected = $('Globals').first().json.TOTAL_SLIDES;\nif (!Array.isArray(parsed.slides) || parsed.slides.length !== expected) {\n  throw new Error(`Expected ${expected} slides, got ${(parsed.slides || []).length}`);\n}\nconst ctx = $('Build Paper Text').item.json;\nreturn [{\n  json: {\n    drive_file_id: ctx.drive_file_id,\n    drive_file_name: ctx.drive_file_name,\n    title: ctx.title,\n    authors: ctx.authors,\n    field: ctx.field,\n    content_hook: parsed.content_hook || '',\n    content_brief: parsed.content_brief || '',\n    slides: parsed.slides,\n    caption: parsed.caption || '',\n    hashtags: parsed.hashtags || [],\n    total_slides: expected\n  }\n}];"
      },

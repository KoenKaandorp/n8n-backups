    {
      "parameters": {
        "jsCode": "const arr = ($json.slide_number || []).map((n, i) => ({\n  slide_number: n,\n  slide_type: $json.slide_type[i],\n  bannerbear_image_url: $json.bannerbear_image_url[i],\n  drive_file_id: $json.drive_file_id[i],\n  drive_view_link: $json.drive_view_link[i]\n}));\narr.sort((a, b) => a.slide_number - b.slide_number);\n\nconst parent = $items('Capture Slide Ref')[0].json._parent;\n\nreturn [{\n  json: {\n    drive_file_id: parent.drive_file_id,\n    title: parent.title,\n    content_hook: parent.content_hook,\n    content_brief: parent.content_brief,\n    slide_urls: arr.map(s => s.bannerbear_image_url).join('\\n'),\n    drive_backup_links: arr.map(s => s.drive_view_link).join('\\n'),\n    caption: parent.caption,\n    hashtags: (parent.hashtags || []).join(' '),\n    generated_at: new Date().toISOString(),\n    status: 'generated'\n  }\n}];"
      },

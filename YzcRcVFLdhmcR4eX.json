    {
      "parameters": {
        "jsCode": "const existing = new Set(\n  $items('Read Existing Papers').map(i => i.json.drive_file_id).filter(Boolean)\n);\nconst pdfs = $items('List PDFs in Drive').map(i => i.json);\nconst unindexed = pdfs\n  .filter(p => !existing.has(p.id))\n  .map(p => ({ json: { drive_file_id: p.id, drive_file_name: p.name } }));\nif (unindexed.length === 0) {\n  return [{ json: { drive_file_id: 'empty', drive_file_name: 'empty' } }];\n}\nreturn unindexed;"
      },
      "id": "af2b3f25-6781-4e81-a048-6845fadd5a43",
      "name": "Filter Unindexed",

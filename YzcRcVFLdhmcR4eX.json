      "id": "fd293566-5d17-43a0-8f65-790d49ffdf70",
      "name": "Extract PDF Per Page",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        1936,
        144
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build a sample for Claude: first ~8 pages tend to hold title/authors/abstract/intro\nconst raw = $json.text || $json.data || '';\nlet pages = [];\nif (Array.isArray(raw)) pages = raw;\nelse if (typeof raw === 'string') {\n  pages = raw.split('\\f');\n  if (pages.length < 3) pages = raw.split(/\\n\\s*\\n\\s*\\n/);\n}\nconst headSample = pages.slice(0, 8)\n  .map((p, idx) => `--- Page ${idx + 1} ---\\n${p.slice(0, 2500)}`)\n  .join('\\n\\n')\n  .slice(0, 18000);\nconst ctx = $('Loop Over Papers').item.json;\nreturn [{\n  json: {\n    drive_file_id: ctx.drive_file_id,\n    drive_file_name: ctx.drive_file_name,\n    total_pages: pages.length,\n    head_sample: headSample\n  }\n}];"
      },
      "id": "80a60eb7-1072-454c-b0c2-0d8c9028ce8c",
      "name": "Build Metadata Sample",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2144,
        144
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are extracting metadata from an academic research paper.\n\nFile name: {{ $json.drive_file_name }}\nTotal pages: {{ $json.total_pages }}\n\n=== FIRST PAGES OF PAPER ===\n{{ $json.head_sample }}\n\nReturn ONLY valid JSON (no markdown fences, no preamble):\n\n{\n  \"title\": \"clean paper title (strip subtitles after a colon if very long)\",\n  \"authors\": \"comma-separated list of primary authors (max 4, then 'et al.')\",\n  \"field\": \"specific subfield, e.g. 'Cognitive Psychology', 'Social Neuroscience', 'Developmental Psychology'\",\n  \"abstract_snippet\": \"first ~200 chars of the abstract verbatim (or a tight paraphrase if no abstract exists)\",\n  \"study_type\": \"one of: experimental | observational | meta-analysis | review | theoretical | other\"\n}\n\nRules:\n- Use information ONLY visible in the sample. If something is missing, use 'Unknown'.\n- Title should be the actual paper title, not the running header or journal name.\n- Do not invent authors or affiliations.",
        "options": {
          "systemMessage": "You are a precise academic metadata extractor. Output strict JSON only, no preamble or markdown fences. When uncertain, prefer 'Unknown' over guessing.",
          "maxIterations": 3
        }
      },
      "id": "584b85b9-ea51-4912-9d7d-df79ea8a50a6",
      "name": "Extract Metadata (Claude)",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        2352,
        144
      ]
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "={{ $('Globals').item.json.ANTHROPIC_MODEL_CHEAP }}",
          "mode": "id"
        },
        "options": {
          "maxTokensToSample": 1500,
          "temperature": 0.1
        }
      },
      "id": "2aefa865-c6d5-4f16-89e5-ea1a0179c169",
      "name": "Metadata Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        2352,
        368
      ],
      "credentials": {
        "anthropicApi": {
          "id": "sUkzGV6H3EB4ekZS",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output || '';\nconst cleaned = raw.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/```\\s*$/i, '').trim();\nlet parsed;\ntry { parsed = JSON.parse(cleaned); } catch (e) {\n  throw new Error('Metadata extraction returned invalid JSON: ' + e.message + ' | raw: ' + raw.slice(0, 300));\n}\nconst meta = $('Build Metadata Sample').item.json;\nreturn [{\n  json: {\n    drive_file_id: meta.drive_file_id,\n    drive_file_name: meta.drive_file_name,\n    title: parsed.title || meta.drive_file_name.replace(/\\.pdf$/i, ''),\n    authors: parsed.authors || 'Unknown',\n    field: parsed.field || 'Unknown',\n    abstract_snippet: (parsed.abstract_snippet || '').slice(0, 500),\n    study_type: parsed.study_type || 'other',\n    indexed_at: new Date().toISOString(),\n    status: 'pending',\n    content_hook: '',\n    content_brief: '',\n    slide_urls: '',\n    caption: '',\n    hashtags: '',\n    generated_at: '',\n    scheduled_for: '',\n    posted_at: '',\n    instagram_post_id: '',\n    error_message: '',\n    notes: ''\n  }\n}];"
      },
      "id": "8fc82ee7-f144-403e-ad8b-1c7614c4da41",
      "name": "Parse Metadata",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2640,
        144
      ]
    },
    {
      "parameters": {
        "content": "\n## Workflow 1 — Paper Indexer\n\nRun manually after dropping PDFs into the papers Drive folder. Scans the folder, dedupes against the papers sheet, extracts paper metadata (title, authors, field, abstract) with Claude Haiku, and appends one row per new paper with `status=pending`.\n\n**Status values:** `pending` (ready for Generator) → `generated` (carousel made, awaiting approval) → `approved` (human flipped it manually) → `posted` (live on Instagram). Plus `failed` / `skipped` for problem rows.\n",
        "height": 228,
        "width": 560,
        "color": 4
      },
      "id": "648fe99a-3372-48a4-8ffb-252b43f4ce12",
      "name": "Sticky Note W1",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [

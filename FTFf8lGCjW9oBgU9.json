    {
      "parameters": {
        "jsCode": "const existing = new Set(\n  $items('Read Existing Manifest').map(i => i.json.drive_file_id).filter(Boolean)\n);\nconst pdfs = $items('List PDFs in Drive').map(i => i.json);\nconst unindexed = pdfs\n  .filter(p => !existing.has(p.id))\n  .map(p => ({ json: { drive_file_id: p.id, drive_file_name: p.name } }));\nif (unindexed.length === 0) {\n  return [{ json: { _empty: true, message: 'No new books to index.' } }];\n}\nreturn unindexed;"
      },
      "id": "cf45ade1-0696-4877-a07e-23352e0a6a09",

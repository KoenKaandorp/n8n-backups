      "id": "1050ef06-6d5d-4f62-b7ed-3e61c3eda124",
      "name": "Extract PDF Per Page",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        416,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.text || $json.data || '';\nlet pages = [];\nif (Array.isArray(raw)) pages = raw;\nelse if (typeof raw === 'string') {\n  pages = raw.split('\\f');\n  if (pages.length < 3) pages = raw.split(/\\n\\s*\\n\\s*\\n/);\n}\nconst summary = pages.map((p, idx) => {\n  const lines = p.split(/\\r?\\n/).map(l => l.trim()).filter(Boolean);\n  return `[Page ${idx + 1}] ${lines.slice(0, 3).join(' | ')}`;\n});\nconst tocCandidates = pages.slice(0, 8).map((p, idx) => `--- Page ${idx + 1} ---\\n${p.slice(0, 1500)}`).join('\\n\\n');\nreturn [{\n  json: {\n    drive_file_id: $('Loop Over Books').item.json.drive_file_id,\n    drive_file_name: $('Loop Over Books').item.json.drive_file_name,\n    total_pages: pages.length,\n    page_summary: summary.join('\\n').slice(0, 18000),\n    toc_sample: tocCandidates.slice(0, 8000)\n  }\n}];"
      },
      "id": "11ce01d6-566f-4c5b-9b5b-98dc1b4c963e",
      "name": "Build TOC Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are analyzing a book PDF to detect chapter boundaries.\n\nFile name: {{ $json.drive_file_name }}\nTotal pages: {{ $json.total_pages }}\n\n=== TABLE OF CONTENTS SAMPLE ===\n{{ $json.toc_sample }}\n\n=== PAGE-BY-PAGE HEAD SUMMARY ===\n{{ $json.page_summary }}\n\nReturn ONLY valid JSON (no markdown fences):\n\n{\n  \"title\": \"clean book title\",\n  \"author\": \"primary author or 'Unknown'\",\n  \"chapters\": [ { \"chapter_number\": 1, \"chapter_title\": \"...\", \"start_page\": 12, \"end_page\": 28 } ]\n}\n\nRules:\n- SKIP front matter (title, copyright, dedication, foreword) and back matter (acknowledgments, bibliography, notes, index)\n- Include Introduction only if substantive\n- Use 1-indexed page numbers matching the [Page N] markers\n- If no chapter structure found, return chapters: []",
        "options": {
          "systemMessage": "You are a precise document-structure parser. Output strict JSON only, no preamble or markdown fences. Prefer fewer-but-correct chapters over guessing.",
          "maxIterations": 3
        }
      },
      "id": "3691addd-3d11-4a58-aa98-df82e57d7948",
      "name": "Detect Chapters (Claude)",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        832,
        0
      ]
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "={{ $('Globals').item.json.ANTHROPIC_MODEL }}",
          "mode": "id"
        },
        "options": {
          "maxTokensToSample": 4000,
          "temperature": 0.1
        }
      },
      "id": "d53ca75a-a7c1-4c11-9bbd-d9d47103141d",
      "name": "Chapter Detect Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        832,
        224
      ],
      "credentials": {
        "anthropicApi": {
          "id": "sUkzGV6H3EB4ekZS",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output || '';\nconst cleaned = raw.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/```\\s*$/i, '').trim();\nlet parsed;\ntry { parsed = JSON.parse(cleaned); } catch (e) {\n  throw new Error('Chapter detection returned invalid JSON: ' + e.message);\n}\nconst chapters = parsed.chapters || [];\nconst meta = $('Build TOC Summary').item.json;\nreturn [{\n  json: {\n    drive_file_id: meta.drive_file_id,\n    title: parsed.title || meta.drive_file_name.replace(/\\.pdf$/i, ''),\n    author: parsed.author || 'Unknown',\n    total_chapters: chapters.length,\n    chapters_covered: 0,\n    chapter_boundaries_json: JSON.stringify(chapters),\n    last_used_at: '',\n    status: chapters.length > 0 ? 'active' : 'no_chapters_detected',\n    notes: '',\n    indexed_at: new Date().toISOString()\n  }\n}];"
      },

    {
      "parameters": {
        "jsCode": "// Build the YouTube description from the queue row. Keep the picked-row fields with the binary.\nconst pick = $('Pick Random Approved').item.json;\nconst kw = (pick.keywords || '').split(',').map(s => s.trim()).filter(Boolean);\nconst hashtags = kw.slice(0, 4).map(k => '#' + k.replace(/[^a-zA-Z0-9]/g, '')).join(' ');\nconst description = `${pick.one_line_summary}\\n\\n${hashtags} #Shorts`;\nconst tags = [...kw, 'psychology', 'shorts'].slice(0, 15);\nreturn [{\n  json: { ...pick, yt_description: description, yt_tags: tags },\n  binary: $binary\n}];"
      },

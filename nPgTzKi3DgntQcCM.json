    {
      "parameters": {
        "jsCode": "// Pick ONE random row with status 'approved'. Report how many approved remain (for the low-queue warning).\nconst rows = $items('Read Queue').map(i => i.json);\nconst approved = rows.filter(r => String(r.status || '').trim().toLowerCase() === 'approved');\n\nif (approved.length === 0) {\n  return [{ json: { _empty: true, approved_remaining: 0, message: 'No approved videos in the queue.' } }];\n}\n\nconst pick = approved[Math.floor(Math.random() * approved.length)];\n// approved_remaining AFTER this one is posted\nconst remaining = approved.length - 1;\n\nreturn [{\n  json: {\n    _empty: false,\n    approved_remaining: remaining,\n    low_queue: remaining < ($('Globals').item.json.QUEUE_LOW_THRESHOLD || 6),\n    video_drive_id: pick.video_drive_id,\n    video_drive_link: pick.video_drive_link,\n    title: pick.title,\n    one_line_summary: pick.one_line_summary,\n    full_script: pick.full_script,\n    keywords: pick.keywords,\n    source_book: pick.source_book,\n    source_chapter: pick.source_chapter,\n    concept_index: pick.concept_index\n  }\n}];"
      },

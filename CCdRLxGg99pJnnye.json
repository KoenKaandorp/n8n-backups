    {
      "parameters": {
        "jsCode": "// Pick the oldest 'approved' row whose scheduled_for is empty or <= today\nconst today = new Date(); today.setHours(23, 59, 59, 999);\nconst todayISO = today.toISOString().slice(0, 10);\nconst rows = $input.all().map(i => i.json);\nconst eligible = rows.filter(r => {\n  if (r.status !== 'approved') return false;\n  if (!r.scheduled_for || String(r.scheduled_for).trim() === '') return true;\n  return String(r.scheduled_for).slice(0, 10) <= todayISO;\n});\nif (eligible.length === 0) {\n  return [{ json: { _empty: true, message: 'No approved rows due today.' } }];\n}\n// Oldest first: prefer scheduled_for ascending, then generated_at ascending\neligible.sort((a, b) => {\n  const aKey = (a.scheduled_for || a.generated_at || '');\n  const bKey = (b.scheduled_for || b.generated_at || '');\n  return String(aKey).localeCompare(String(bKey));\n});\nconst pick = eligible[0];\nconst slideUrls = String(pick.slide_urls || '').split(/\\r?\\n/).map(s => s.trim()).filter(Boolean);\nif (slideUrls.length < 2) {\n  return [{ json: { _empty: true, message: 'Picked row has <2 slide URLs, skipping. row=' + pick.drive_file_id } }];\n}\nreturn [{\n  json: {\n    drive_file_id: pick.drive_file_id,\n    title: pick.title,\n    caption: pick.caption || '',\n    hashtags: pick.hashtags || '',\n    slide_urls: slideUrls\n  }\n}];"
      },

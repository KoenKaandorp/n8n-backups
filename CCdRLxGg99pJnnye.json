      "parameters": {
        "jsCode": "const arr = ($json.slide_index || []).map((idx, i) => ({\n  slide_index: idx,\n  container_id: $json.container_id[i]\n}));\narr.sort((a, b) => a.slide_index - b.slide_index);\n\nconst parent = $items('Capture Container ID')[0].json._parent;\nconst caption = [parent.caption, parent.hashtags].filter(Boolean).join('\\n\\n');\n\nreturn [{\n  json: {\n    ...parent,\n    children_csv: arr.map(c => c.container_id).join(','),\n    full_caption: caption\n  }\n}];"

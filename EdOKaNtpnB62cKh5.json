    {
      "parameters": {
        "operation": "extractHtmlContent",
        "extractionValues": {
          "values": [
            {
              "key": "pdfLinks",
              "cssSelector": "a[href$=\".pdf\"], a[href*=\".pdf?\"]",
              "returnValue": "attribute",
              "attribute": "href",
              "returnArray": true
            },
            {
              "key": "pdfTitles",
              "cssSelector": "a[href$=\".pdf\"], a[href*=\".pdf?\"]",
              "returnArray": true
            }
          ]
        },
        "options": {}
      },
      "id": "d5a7de87-de43-44ec-a1ab-d78e554e5efe",
      "name": "Extract PDF Links",
      "type": "n8n-nodes-base.html",
      "typeVersion": 1,
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// === CONFIGURE THIS ===\nconst BASE_URL = 'https://REPLACE_WITH_TARGET_URL.com';\n\nconst input = $input.first().json;\nconst links = input.pdfLinks || [];\nconst titles = input.pdfTitles || [];\n\nconst items = links.map((link, i) => {\n  let fullUrl = link;\n  if (link.startsWith('//')) {\n    fullUrl = 'https:' + link;\n  } else if (link.startsWith('/')) {\n    fullUrl = BASE_URL.replace(/\\/$/, '') + link;\n  } else if (!link.startsWith('http')) {\n    fullUrl = BASE_URL.replace(/\\/$/, '') + '/' + link;\n  }\n\n  const urlParts = fullUrl.split('?')[0].split('/');\n  const filename = decodeURIComponent(urlParts[urlParts.length - 1]);\n  const title = (titles[i] || filename).trim().replace(/\\s+/g, ' ');\n\n  return {\n    json: {\n      url: fullUrl,\n      filename: filename,\n      title: title\n    }\n  };\n});\n\n// Deduplicate by URL within this run\nconst seen = new Set();\nreturn items.filter(item => {\n  if (seen.has(item.json.url)) return false;\n  seen.add(item.json.url);\n  return true;\n});\n"
      },

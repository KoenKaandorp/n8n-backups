    },
    {
      "parameters": {
        "jsCode": "// Get existing URLs from the tracking sheet\nconst existingRows = $('Read Tracking Sheet').all();\nconst existingUrls = new Set(\n  existingRows\n    .map(r => (r.json.url || '').trim())\n    .filter(u => u.length > 0)\n);\n\n// Get freshly scraped PDF list\nconst scraped = $('Normalize PDF List').all();\n\n// Keep only ones not already in the sheet\nconst newOnes = scraped.filter(item => !existingUrls.has(item.json.url));\n\nreturn newOnes;\n"
      },
